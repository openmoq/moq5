# Installed pico WT adapter target — relocatable via prefix detection.
# File lands at <prefix>/lib/cmake/libmoq/, so four PATH ascents reach
# the install prefix.
get_filename_component(_PICOWT_PREFIX "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(_PICOWT_PREFIX "${_PICOWT_PREFIX}" PATH)
get_filename_component(_PICOWT_PREFIX "${_PICOWT_PREFIX}" PATH)
get_filename_component(_PICOWT_PREFIX "${_PICOWT_PREFIX}" PATH)

if(NOT TARGET moq::adapter-pico-wt)
  add_library(moq::adapter-pico-wt @_picowt_lib_type@ IMPORTED)
  set_target_properties(moq::adapter-pico-wt PROPERTIES
    IMPORTED_LOCATION "${_PICOWT_PREFIX}/@_picowt_libdir@/@_picowt_lib_name@"
    INTERFACE_INCLUDE_DIRECTORIES "${_PICOWT_PREFIX}/@_picowt_incdir@"
    INTERFACE_LINK_LIBRARIES "moq::core;OpenSSL::SSL;OpenSSL::Crypto;picoquic::picohttp-core")
endif()

unset(_PICOWT_PREFIX)
